{
  "name": "soundbite",
  "version": "0.1.0",
  "description": "Local forensic audio recorder and Voice Memos clip manager.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "build:helper": "clang -Wall -Wextra -O2 -framework CoreAudio -framework CoreFoundation src/macos-audio-hog-wrapper.c -o src/macos-audio-hog-wrapper",
    "start": "electron .",
    "package:mac": "npm run build:helper && electron-packager . SoundBite --platform=darwin --arch=x64 --out=dist --overwrite --prune=true --ignore='^/dist($|/)' --ignore='^/test($|/)' --extra-resource=src/macos-audio-hog-wrapper",
    "open:mac": "open dist/SoundBite-darwin-x64/SoundBite.app",
    "doctor": "node src/doctor.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^42.3.3"
  }
}
